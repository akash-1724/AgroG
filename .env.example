# AgroGuide Environment Variables Configuration Template
# Copy this file to '.env' and fill in your local developer configurations.

# Backend Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=True
DATABASE_URL=postgresql+asyncpg://postgres:your_db_password_here@localhost:5432/agroguide
REDIS_URL=redis://localhost:6379/0

# Security / Token Auth
JWT_SECRET=your_jwt_access_secret_token_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_token_here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Cloudinary Integration
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name_here

# ML Service Settings
ML_SERVICE_URL=http://localhost:8001
GEMINI_API_KEY=your-gemini-api-key-here

# ML Configuration
CROP_MODEL_PATH=models/crop_xgb.json
FERTILIZER_MODEL_PATH=models/fertilizer_dt.pkl
ML_DEMO_MODE=True
MAX_IMAGE_UPLOAD_MB=5

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
